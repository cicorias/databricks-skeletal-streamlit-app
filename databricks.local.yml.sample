# Copy this file to databricks.local.yml and fill in your values.
# databricks.local.yml is gitignored — do not commit it.

variables:
  app_name:
    description: Databricks App name
    default: streamlit-app
  warehouse_id:
    description: SQL warehouse ID for the app
    default: <your-warehouse-id>
  catalog:
    default: dev
  schema:
    default: default

targets:
  dev:
    workspace:
      host: "https://adb-<workspace-id>.<region>.azuredatabricks.net/"
      # eg       host: "https://adb-1234561234567890.9.azuredatabricks.net/"
      auth_type: azure-cli
      profile: dev