# Local dev configuration for the Flask backend.
# Copy to .env (gitignored) and fill in your workspace values.

# ── Workspace target ──────────────────────────────────────────
# Hostname WITHOUT the leading https://
DATABRICKS_HOST=adb-<workspace-id>.<region>.azuredatabricks.net

# SQL warehouse to query (look up with: databricks warehouses list -p dev)
DATABRICKS_WAREHOUSE_ID=<warehouse-id>

# ── Auth — pick ONE of the two strategies ─────────────────────

# Strategy A: Service Principal (recommended; mirrors deployed Databricks Apps SP auth)
# Create a workspace SP, assign it CAN_USE on the warehouse + SELECT on the
# tables this app reads, then paste its client id + secret here.
# DATABRICKS_CLIENT_ID=<sp-client-id>
# DATABRICKS_CLIENT_SECRET=<sp-client-secret>

# Strategy B: User OAuth bearer token (quick start, but token expires hourly)
# Run: databricks auth token -p dev | jq -r .access_token
DATABRICKS_TOKEN=<paste-token-here>

# ── Catalog / schema ──────────────────────────────────────────
DATABRICKS_CATALOG=dev
DATABRICKS_SCHEMA=default

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=8000
