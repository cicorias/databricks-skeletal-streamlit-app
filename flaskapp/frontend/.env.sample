# Vite reads variables prefixed with VITE_* into client code at build time.
# Variables WITHOUT the VITE_ prefix are only available in vite.config.ts (Node side).

# Mode 1 (default): local backend
# VITE_LOCAL_BACKEND_URL=http://localhost:8000

# Mode 2: remote backend on Databricks Apps
# VITE_BACKEND_MODE=remote
# VITE_REMOTE_BACKEND_URL=https://sales-dashboard-flask-<workspace-id>.<region>.azure.databricksapps.com
# DATABRICKS_TOKEN=<bearer-token-from-`databricks auth token -p dev | jq -r .access_token`>
